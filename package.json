{
  "name": "@zeroexcore/trader",
  "version": "3.0.1",
  "description": "Solana trading CLI - Trade tokens, track portfolio, bet on prediction markets",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "trader": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zeroexcore/trader"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "trading",
    "cli",
    "openclaw",
    "rwa",
    "defi"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "0.29.0",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "big.js": "7.0.1",
    "commander": "12.1.0",
    "dotenv": "16.6.1",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@types/big.js": "6.2.2",
    "@types/bn.js": "^5.2.0",
    "@types/node": "25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
